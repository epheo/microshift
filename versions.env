# Single source of truth for every pinned input of the build.
# Bumped by scripts/bump-versions.sh (via the scheduled bump workflow) or by hand.

# openshift/microshift source ref. Pin release (ART) tags, not branches, so
# builds are reproducible; z-streams within the pinned minor land here.
USHIFT_GIT_URL=https://github.com/openshift/microshift.git
USHIFT_GITREF=4.22.3-202606251354.p0

# OKD payload the component images are swapped to (quay.io/okd/scos-release
# tags). Stay on stable (-okd-scos.N) tags of the same minor as USHIFT_GITREF.
OKD_VERSION_TAG=4.22.0-okd-scos.6
OKD_RELEASE_IMAGE=quay.io/okd/scos-release

# Base images. The RPM buildroot is CentOS Stream 10 => native el10 RPMs
# (upstream spec supports rhel>=10; stream10 golang satisfies the >=1.25 need).
BOOTC_IMAGE_URL=quay.io/centos-bootc/centos-bootc
BOOTC_IMAGE_TAG=stream10
BUILDROOT_IMAGE=quay.io/centos/centos:stream10

# Edge component shipped by this distribution (embedded as an OCI archive,
# imported into cri-o's store at boot — see src/embedded-images/).
PORTAIL_IMAGE=ghcr.io/epheo/portail:0.1.16

# Revision of this repo's patch/opinion set. Bump when patches/ or the
# opinionated configuration changes without any upstream version change.
EPHEO_REV=3
